# Скопируй эти ИМЕНА в Railway → Variables и подставь свои ЗНАЧЕНИЯ.
# В репозитории значения не хранить.

TELEGRAM_BOT_TOKEN=
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
# Или напрямую: LLM_PROVIDER=openai, LLM_MODEL=gpt-4o-mini, OPENAI_API_KEY=sk-...

# Для БД и будущего экспорта в Google Sheets (добавь Postgres в Railway):
# DATABASE_URL=postgresql://...

# Опционально:
# SET_WEBHOOK=true
# LOG_LEVEL=info
# FORMAT_PROMPT=
# PORT=3000
# LLM_TEMPERATURE=70
# LLM_MAX_OUTPUT_TOKENS=4096

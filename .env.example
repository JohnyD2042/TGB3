# Скопируй эти ИМЕНА в Railway → Variables и подставь свои ЗНАЧЕНИЯ.
# В репозитории значения не хранить.

TELEGRAM_BOT_TOKEN=
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=
# Или напрямую: LLM_PROVIDER=openai, LLM_MODEL=gpt-4o-mini, OPENAI_API_KEY=sk-...

# Для БД и кнопки «Отправить в таблицу» (добавь Postgres в Railway):
# DATABASE_URL=postgresql://...

# Для выгрузки в Google Таблицу по кнопке (опционально):
# GOOGLE_SHEET_ID=     — ID таблицы из URL (между /d/ и /edit)
# GOOGLE_SHEETS_CREDENTIALS_JSON=  — весь JSON ключа сервисного аккаунта одной строкой

# Опционально:
# SET_WEBHOOK=true
# LOG_LEVEL=info
# FORMAT_PROMPT=
# PORT=3000
# LLM_TEMPERATURE=70
# LLM_MAX_OUTPUT_TOKENS=4096

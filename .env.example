# Скопируй эти имена в Railway → твой сервис → Variables.
# Значения вводи сам (токены и ключи не коммитить).

# === Обязательные ===
TELEGRAM_BOT_TOKEN=
REDIS_URL=
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Если используешь Anthropic вместо OpenAI:
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=

# === Railway обычно подставляет сам ===
PORT=3000

# === Опционально ===
# SET_WEBHOOK=true
# LOG_LEVEL=info
# FORMAT_PROMPT=
# PREFILTER_MODE=off
# WORKER_CONCURRENCY=2
# TELEGRAM_SEND_DELAY_MS=300
# LLM_TEMPERATURE=70
# LLM_MAX_OUTPUT_TOKENS=4096
